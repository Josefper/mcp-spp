# One Identity Safeguard for Privileged Passwords – MCP Server Configuration

# Required: Appliance URL (e.g. https://safeguard.example.com)
SPP_APPLIANCE_URL=https://your-safeguard-appliance

# Optional: Disable SSL verification for self-signed certs (default: false)
SPP_VERIFY_SSL=false

# Optional: API version (default: v4)
SPP_API_VERSION=v4

# Optional: Default credentials (can also be passed per tool call)
SPP_USERNAME=
SPP_PASSWORD=

# Optional: Default identity provider (default: local)
SPP_PROVIDER=local
